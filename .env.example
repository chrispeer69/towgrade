# Copy to .env.local and fill in real values from your Supabase project dashboard
# (Project Settings → API). Never commit .env.local.

# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-only — bypasses RLS. Never expose to the browser. Used for admin tasks
# (manual operator verification, seed scripts, migrations run from app code).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site origin used as the base for auth email redirect URLs.
# Localhost in dev, https://www.towgrade.com on Vercel for prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — Resend API key for transactional email sent directly from the
# app (e.g. the per-registration admin notification). Distinct from the SMTP
# credential Supabase Auth uses for operator confirmation emails. Generate a
# dedicated app-server key in the Resend dashboard so it can be rotated
# independently. Required by src/lib/resend.ts.
RESEND_API_KEY=re_your_app_server_key

# CLI-only — Supabase Personal Access Token + DB connection string. Used by
# `npx supabase` to apply migrations and regenerate types. Not read by the app.
# SUPABASE_ACCESS_TOKEN=sbp_xxx
# SUPABASE_DB_URL=postgresql://postgres.PROJECT-REF:PASSWORD@aws-X-REGION.pooler.supabase.com:6543/postgres
